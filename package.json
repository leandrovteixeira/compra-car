{
  "name": "compra-car",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20.0.0 <25",
    "pnpm": ">=10.0.0 <11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@compra-car/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "start": "pnpm --filter @compra-car/web start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  }
}
