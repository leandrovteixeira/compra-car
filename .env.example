# Supabase Auth no browser e no SSR. A publishable key (ou anon key legada)
# é pública por definição e nunca deve ser substituída por secret/service_role.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Runtime do servidor. Nunca use NEXT_PUBLIC_ para estas credenciais.
SUPABASE_URL=
SUPABASE_SERVER_KEY=

# Testes de integração opt-in e somente leitura.
SUPABASE_INTEGRATION_URL=
SUPABASE_INTEGRATION_SERVER_KEY=
SUPABASE_INTEGRATION_VEHICLE_IDS=
